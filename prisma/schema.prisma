// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

model Professional {
  id        Int      @id @default(autoincrement())
  nombre    String
  run       String?
  rol       String   // e.g. "Fonoaudióloga"
  correo    String   @unique
  password  String
  isAdmin   Boolean  @default(false)
  activo    Boolean  @default(true)
  materials Material[]
}

model Student {
  id          Int      @id @default(autoincrement())
  nombre      String
  rut         String   @unique
  curso       String
  sexo        String   @default("No especificado")
  fechaNacimiento String?
  fotoUrl     String?
  diagnostico String
  apoderado   String
  direccion   String?
  parentesco  String?
  telefono    String
  correo      String
  token       String?  @unique
  materials   Material[]
}

model Material {
  id              Int      @id @default(autoincrement())
  actividad       String
  asignatura      String
  objetivos       String
  recomendaciones String?
  fecha_carga     String
  fecha_inicio    String
  fecha_termino   String
  estado          String   @default("Pendiente")
  acceso          String   @default("Sin acceso")
  link            String?
  archivo_url     String?
  archivoUrl      String?
  fecha_apertura  DateTime?
  tiempo_total_segundos Int @default(0)

  professionalId  Int
  professional    Professional @relation(fields: [professionalId], references: [id])
  
  studentId       Int
  student         Student      @relation(fields: [studentId], references: [id])
}
